# ── Configuration RepairMate ───────────────────────────────────────
# Copier ce fichier en .env et remplir les valeurs réelles
# Ne JAMAIS committer le fichier .env dans Git

# Port du serveur (défaut : 3000)
PORT=3000

# Clé secrète pour les sessions Express (changer en production !)
SESSION_SECRET=repairmate_secret_key_change_in_prod

# Environnement : development | production
NODE_ENV=development
